{
  "rewrites": [
    {
      "source": "/",
      "destination": "/yale-housing-catalog/index.html"
    },
    {
      "source": "/index.html",
      "destination": "/yale-housing-catalog/index.html"
    },
    {
      "source": "/catalog.html",
      "destination": "/yale-housing-catalog/catalog.html"
    },
    {
      "source": "/styles.css",
      "destination": "/yale-housing-catalog/styles.css"
    },
    {
      "source": "/logo-styles.css",
      "destination": "/yale-housing-catalog/logo-styles.css"
    },
    {
      "source": "/data.js",
      "destination": "/yale-housing-catalog/data.js"
    },
    {
      "source": "/home.js",
      "destination": "/yale-housing-catalog/home.js"
    },
    {
      "source": "/catalog.js",
      "destination": "/yale-housing-catalog/catalog.js"
    },
    {
      "source": "/assets/(.*)",
      "destination": "/yale-housing-catalog/assets/$1"
    }
  ]
}
